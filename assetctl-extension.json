{
  "schema_version": "1.0",
  "extension_id": "ai-asset-contribution-gate",
  "name": "AI Asset Contribution Safety Gate",
  "version": "v0.3.8",
  "repository": "Kdreammaker/ai-asset-contribution-gate",
  "public_safe_by_default": true,
  "default_mode": "fixture-only",
  "required_runtimes": {
    "powershell": "5.1+",
    "python": "3.9+",
    "git": "recommended",
    "node": "optional"
  },
  "local_runtime_paths": [
    "reports/",
    "reports/connector/",
    ".assetctl/",
    ".assetctl/requests/",
    ".assetctl/cache/",
    ".assetctl-private-connector.local.json"
  ],
  "commands": {
    "bootstrap": "./tools/bootstrap-workspace.ps1",
    "doctor": "./tools/assetctl-doctor.ps1",
    "user_profile": "./tools/user-profile.ps1",
    "candidate_validate": "./tools/candidate-gate.ps1 -Operation validate-fixtures -AssetsRoot .",
    "connector_validate": "./tools/connector-client.ps1 -Operation validate-fixtures",
    "connector_bundle_request": "./tools/connector-client.ps1 -Operation bundle-request",
    "connector_ppt_metadata_bundles": "./tools/connector-client.ps1 -Operation ppt-metadata-bundles",
    "connector_validate_handoff": "./tools/connector-client.ps1 -Operation validate-handoff",
    "local_private_connector": "./tools/invoke-private-connector.ps1",
    "private_attach": "./tools/user-profile.ps1 -Operation authorize -AcceptNotice ..."
  },
  "safe_capabilities": [
    "validate synthetic candidate fixtures",
    "validate public connector schemas and fixtures",
    "create public-safe connector request files",
    "create public-only request bundles for private-side handoff",
    "validate returned public-safe handoff responses",
    "search public-safe metadata fixtures",
    "run public-safe leak scans",
    "check release updates when explicitly requested"
  ],
  "private_attach_boundary": {
    "requires_user_authorized_profile": true,
    "does_not_auto_clone_private_repo": true,
    "does_not_guess_private_paths_by_default": true,
    "stores_profile_outside_repo": true,
    "logs_connection_events_locally": true,
    "does_not_copy_private_registry_or_drive_data": true,
    "supported_modes": [
      "local-maintainer-explicit-path",
      "external-safe-proxy-metadata"
    ]
  },
  "tracked_data_policy": {
    "allowed": [
      "schemas",
      "synthetic fixtures",
      "public-safe docs",
      "public-safe scripts"
    ],
    "forbidden": [
      "raw private assets",
      "private registry exports",
      "Drive IDs",
      "Slack tokens or channel IDs",
      "host bridge paths",
      "approval records",
      "generated private reports",
      "local absolute private paths"
    ]
  }
}
